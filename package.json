{
  "name": "baoyan-pilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "sync:schools": "node scripts/sync-schools.mjs",
    "crawl:college-sources": "node scripts/crawl-college-sources.mjs",
    "crawl:units": "node scripts/academic-units/crawlAcademicUnits.mjs",
    "crawl:units:batch": "node scripts/academic-units/crawlAllSchools.mjs",
    "crawl:units:all": "node scripts/academic-units/crawlAllSchools.mjs",
    "crawl:units:resume": "node scripts/academic-units/crawlAllSchools.mjs --all --resume",
    "crawl:units:failed": "node scripts/academic-units/crawlAllSchools.mjs --failed-only",
    "crawl:units:remaining": "node scripts/academic-units/crawlAllSchools.mjs --all --resume --unprocessed-only",
    "crawl:units:review": "node scripts/academic-units/crawlAllSchools.mjs --retry-review",
    "crawl:units:source-failed": "node scripts/academic-units/crawlAllSchools.mjs --retry-source-not-found",
    "crawl:units:crawl-failed": "node scripts/academic-units/crawlAllSchools.mjs --retry-crawl-failed",
    "crawl:units:parse-failed": "node scripts/academic-units/crawlAllSchools.mjs --retry-parse-failed",
    "crawl:units:blocked": "node scripts/academic-units/crawlAllSchools.mjs --retry-blocked",
    "crawl:units:full-report": "node scripts/academic-units/generateFullReport.mjs",
    "crawl:units:school": "node scripts/academic-units/runAcademicUnitPipeline.mjs --school",
    "debug:units": "node scripts/academic-units/debugAcademicUnits.mjs",
    "crawl:units:debug": "node scripts/academic-units/debugAcademicUnits.mjs",
    "debug:search": "node scripts/search-providers/debugSearch.mjs",
    "validate:units": "node scripts/academic-units/validateAcademicUnits.mjs",
    "report:units": "node scripts/academic-units/generateReport.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cheerio": "^1.2.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11"
  }
}
